---
interface Props {
  type?: "info" | "warn" | "pqc" | "default";
  title?: string;
}
const { type = "default", title } = Astro.props;

const ICONS: Record<string, string> = {
  info: `<circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>`,
  warn: `<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
  pqc: `<path d="M12 2 3 6v6c0 5 3.8 9.5 9 10 5.2-.5 9-5 9-10V6l-9-4z"/><path d="M8.5 12.5l2.5 2.5 4.5-5"/>`,
  default: `<circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>`,
};
---
<div class:list={["callout", type]}>
  <svg class="callout-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[type]}></svg>
  <div class="callout-body">
    {title && <strong>{title}</strong>}
    <slot />
  </div>
</div>
