---
interface Props {
  prev?: { href: string; label: string };
  next?: { href: string; label: string };
}
const { prev, next } = Astro.props;
---
<div class="page-foot-nav">
  {prev ? (
    <a href={prev.href} class="foot-nav">
      <div class="foot-nav-label">Previous</div>
      <div class="foot-nav-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 5l-7 7 7 7"/></svg>
        {prev.label}
      </div>
    </a>
  ) : <div />}
  {next ? (
    <a href={next.href} class="foot-nav next">
      <div class="foot-nav-label">Next</div>
      <div class="foot-nav-title">
        {next.label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </div>
    </a>
  ) : <div />}
</div>
