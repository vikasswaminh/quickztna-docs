---
// QuickZTNA docs logo — marketing site's nested-square mark + "/ docs" suffix
---
<a href="/" class="logo">
  <span class="logo-mark">
    <svg viewBox="0 0 32 32" width="20" height="20" aria-hidden="true">
      <rect x="0" y="0" width="32" height="32" rx="7" fill="transparent"/>
      <rect x="3" y="3" width="26" height="26" rx="5" fill="#ffffff" fill-opacity="0.92"/>
      <rect x="7" y="7" width="18" height="18" rx="3" fill="url(#qz-grad)"/>
      <defs>
        <linearGradient id="qz-grad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#6366F1"/>
          <stop offset="100%" stop-color="#4338CA"/>
        </linearGradient>
      </defs>
    </svg>
  </span>
  <span>QuickZTNA</span>
  <span class="logo-suffix">/ docs</span>
</a>
