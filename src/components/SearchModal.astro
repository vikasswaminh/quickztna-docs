---
<div class="modal-backdrop" id="search-modal" role="dialog" aria-modal="true" aria-label="Search docs">
  <div class="search-modal">
    <div class="search-input-row">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input
        type="text"
        class="search-input"
        id="search-input"
        placeholder="Search documentation, APIs, CLI…"
        autocomplete="off"
        spellcheck="false"
      />
      <span class="kbd">ESC</span>
    </div>
    <div class="search-results" id="search-results"></div>
    <div class="search-footer">
      <span class="search-footer-item">↑↓ Navigate</span>
      <span class="search-footer-item">↵ Open</span>
      <span class="search-footer-item" style="margin-left:auto;">QuickZTNA docs</span>
    </div>
  </div>
</div>

<script is:inline define:vars={{ SEARCH_INDEX }}>
  const modal = document.getElementById("search-modal");
  const input = document.getElementById("search-input");
  const results = document.getElementById("search-results");
  const trigger = document.getElementById("search-trigger");

  let selIdx = 0;
  let currentResults = SEARCH_INDEX.slice(0, 8);

  function render() {
    if (!results) return;
    if (currentResults.length === 0) {
      results.innerHTML = '<div class="search-empty">No results</div>';
      return;
    }
    const grouped = {};
    currentResults.forEach((r) => {
      (grouped[r.group] = grouped[r.group] || []).push(r);
    });
    let i = -1;
    results.innerHTML = Object.entries(grouped)
      .map(([g, items]) => {
        return `<div class="search-group-title">${g}</div>` + items.map((r) => {
          i += 1;
          const isSel = i === selIdx;
          return `<a class="search-result${isSel ? " sel" : ""}" href="${r.href}" data-idx="${i}">
            <div class="search-result-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <div class="search-result-body">
              <div class="search-result-title">${r.title}</div>
              <div class="search-result-breadcrumb">${r.breadcrumb}</div>
            </div>
          </a>`;
        }).join("");
      })
      .join("");
  }

  function update(q) {
    const t = (q || "").toLowerCase().trim();
    currentResults = t
      ? SEARCH_INDEX.filter((r) => r.title.toLowerCase().includes(t) || r.breadcrumb.toLowerCase().includes(t))
      : SEARCH_INDEX.slice(0, 8);
    selIdx = 0;
    render();
  }

  function open() {
    modal?.classList.add("open");
    setTimeout(() => input?.focus(), 40);
    update("");
  }
  function close() {
    modal?.classList.remove("open");
    if (input) input.value = "";
  }

  trigger?.addEventListener("click", open);

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      if (modal?.classList.contains("open")) close();
      else open();
    }
    if (!modal?.classList.contains("open")) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowDown") {
      e.preventDefault();
      selIdx = Math.min(selIdx + 1, currentResults.length - 1);
      render();
    }
    if (e.key === "ArrowUp") {
      e.preventDefault();
      selIdx = Math.max(selIdx - 1, 0);
      render();
    }
    if (e.key === "Enter") {
      e.preventDefault();
      const r = currentResults[selIdx];
      if (r) window.location.href = r.href;
    }
  });

  modal?.addEventListener("click", (e) => {
    if (e.target === modal) close();
  });

  input?.addEventListener("input", (e) => update(e.target.value));
</script>
