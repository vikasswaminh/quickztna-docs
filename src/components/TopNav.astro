---
import Logo from "./Logo.astro";

interface Props {
  current?: string;
}
const { current } = Astro.props;

const links = [
  { href: "/", label: "Documentation", match: ["index", "landing"] },
  { href: "/quickstart", label: "Quickstart", match: ["quickstart"] },
  { href: "/api", label: "API Reference", match: ["api"] },
  { href: "/cli", label: "CLI", match: ["cli"] },
  { href: "https://quickztna.com/changelog", label: "Changelog", external: true },
];

const AUTH_URL = "https://login.quickztna.com/auth";
---
<header class="topnav">
  <Logo />
  <nav class="topnav-links">
    {links.map((l) => (
      <a
        href={l.href}
        target={l.external ? "_blank" : undefined}
        rel={l.external ? "noopener noreferrer" : undefined}
        class:list={["topnav-link", l.match?.includes(current ?? "") && "active"]}
      >
        {l.label}
      </a>
    ))}
  </nav>
  <div class="topnav-right">
    <button class="search-trigger" id="search-trigger" aria-label="Search docs">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <span class="search-trigger-text">Search docs…</span>
      <span class="kbd">⌘K</span>
    </button>
    <a href="https://github.com/quickztna" target="_blank" rel="noopener noreferrer" class="btn btn-ghost" title="GitHub">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.04c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.31-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.47 11.47 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.87.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.58C20.57 21.79 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
    </a>
    <a href={AUTH_URL} class="btn btn-secondary">Sign in</a>
    <a href={AUTH_URL} class="btn btn-primary">
      Get API keys
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>
</header>
