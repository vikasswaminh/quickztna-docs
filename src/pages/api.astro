<span class="tok-c"># Output: tskey-auth-abc123...</span>`,
  },
  {
    lang: "Terraform",
    code: `<span class="tok-k">resource</span> <span class="tok-s">"quickztna_auth_key"</span> <span class="tok-s">"fleet_rollout"</span> {
  org_id     = <span class="tok-s">"org_9fX2kRmBnqT4"</span>
